{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.example", "tsconfig.json"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "src/schema.d.ts"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "test:int": {
      "cache": false
    },
    "generate:openapi": {
      "cache": false
    },
    "e2e": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
