{
  "openapi": "3.0.0",
  "paths": {
    "/v1/external/todos/{id}": {
      "get": {
        "description": "Proxied through the resilience policy (retry + circuit breaker + timeout).",
        "operationId": "ExternalController_fetchTodo_v1",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExternalTodoDto"
                }
              }
            }
          },
          "400": {
            "description": "id must be an integer"
          },
          "401": {
            "description": "Missing or invalid token"
          },
          "503": {
            "description": "Circuit open — external API unavailable"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Fetch a TODO from the demo external API",
        "tags": [
          "external"
        ]
      }
    },
    "/health/liveness": {
