  "info": {
    "title": "NestJS Service Template",
    "description": "Production-grade service template API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "ExternalTodoDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "userId": {
            "type": "number",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "delectus aut autem"
          },
          "completed": {
            "type": "boolean",
            "example": false
          }
        },
        "required": [
          "id",
          "userId",
          "title",
          "completed"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "grace@example.dev",
            "description": "Unique login email"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "example": "correct-horse-battery"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "user",
                "admin"
              ]
            },
            "example": [
              "user"
            ]
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "example": "grace@example.dev"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "user",
                "admin"
              ]
            }
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "roles",
          "isActive",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "grace@example.dev",
            "description": "Unique login email"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "user",
                "admin"
              ]
            },
            "example": [
              "user"
            ]
          },
          "isActive": {
            "type": "boolean",
            "description": "Soft-disable the account"
          }
        }
      },
      "UserCreatedEvent": {
        "type": "object",
        "properties": {}
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "ada@example.dev",
            "description": "Unique login email"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "example": "correct-horse-battery"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthTokensDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Bearer access token (JWT)"
          }
        },
        "required": [
          "accessToken"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "ada@example.dev"
          },
          "password": {
            "type": "string",
            "example": "correct-horse-battery"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ProfileDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "example": "ada@example.dev"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "user",
                "admin"
              ]
            }
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "users:read",
                "users:write"
              ]
            },
            "description": "Granted at token issuance"
          }
        },
        "required": [
          "userId",
          "email",
          "roles",
          "permissions"
        ]
      }
    }
  }
}
