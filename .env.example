# --- core ---
NODE_ENV=development
PORT=3000
CORS_ORIGINS=*
LOG_LEVEL=info
SWAGGER_ENABLED=true

# --- database ---
DATABASE_URL=postgres://app:app@localhost:5432/app

# --- auth (JWT_SECRET is REQUIRED in production, min 32 chars) ---
JWT_SECRET=dev-only-secret-change-me-32-chars!!
JWT_EXPIRES_IN=15m

# --- cache (REDIS_URL unset -> in-memory) ---
REDIS_URL=redis://localhost:6379
CACHE_TTL_MS=30000

# --- messaging (kafka | sqs | none; unselected transports never connect) ---
MESSAGING_DRIVER=none
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nestjs-service-template
KAFKA_GROUP_ID=nestjs-service-template
# SQS_QUEUE_URL is REQUIRED when MESSAGING_DRIVER=sqs; SQS_ENDPOINT only for LocalStack
SQS_QUEUE_URL=http://localhost:4566/000000000000/user-events
SQS_REGION=us-east-1
SQS_ENDPOINT=http://localhost:4566

# --- external HTTP (demo dependency behind retry + circuit breaker + timeout) ---
EXTERNAL_API_URL=https://jsonplaceholder.typicode.com
