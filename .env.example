# --- core ---
NODE_ENV=development
PORT=3000
CORS_ORIGINS=*
LOG_LEVEL=info
SWAGGER_ENABLED=true

# --- database ---
DATABASE_URL=postgres://app:app@localhost:5432/app

# --- auth (JWT_SECRET is REQUIRED in production, min 32 chars) ---
JWT_SECRET=dev-only-secret-change-me-32-chars!!
JWT_EXPIRES_IN=15m

# --- cache (REDIS_URL unset -> in-memory) ---
REDIS_URL=redis://localhost:6379
CACHE_TTL_MS=30000
